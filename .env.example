# Configuraciones de Entorno para ProyectoEUDE
# Copiar este archivo a .env y ajustar los valores para desarrollo local

# Base de Datos (Ejemplo)
DB_HOST=localhost
DB_PORT=5432
DB_USER=usuario
DB_PASSWORD=secreto
DB_NAME=eude_db

# Directorios de Datos
DATA_DIR=data/
RAW_DATA_DIR=data/raw/
PROCESSED_DATA_DIR=data/processed/

# API Keys Externas (Ejemplo, para APIs de extracción)
# EXTERNAL_API_KEY=tu_api_key_aqui
